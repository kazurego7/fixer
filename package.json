{
  "name": "codex-mobile-ui",
  "version": "0.1.0",
  "description": "Mobile web UI for local Codex App Server",
  "main": "server/index.ts",
  "scripts": {
    "start": "tsx server/index.ts",
    "start:watch": "tsx watch server/index.ts",
    "build": "vite build --config vite.config.ts",
    "build:watch": "vite build --watch --config vite.config.ts",
    "dev": "bash -lc \"trap 'kill 0' EXIT; npm run build:watch & npm run start:watch\"",
    "web:dev": "vite --config vite.config.ts",
    "test": "tsx --test test/*.test.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:file-list-regression": "playwright test --config playwright.config.ts e2e/file-list-regression.spec.ts",
    "test:e2e:git-visual": "playwright test --config playwright.config.ts e2e/git-visual.spec.ts",
    "test:e2e:file-tree-visual": "playwright test --config playwright.config.ts e2e/file-tree-visual.spec.ts",
    "test:e2e:file-diff-visual": "playwright test --config playwright.config.ts e2e/file-diff-visual.spec.ts",
    "test:smoke": "playwright test --config playwright.config.ts --grep @smoke",
    "test:all": "npm test && npm run test:smoke"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "fastify": "^5.7.4",
    "framework7": "^9.0.3",
    "framework7-react": "^9.0.3",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-push": "^3.6.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
